---
import '../styles/global.css';
import Cursor from '../components/Cursor';
import EthicsGrid from '../components/EthicsGrid';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Sotiris Iliadis — AI Ethical Designer',
  description = 'AI Ethical Designer with 13+ years of experience. Specialising in EU AI Act compliance, WCAG 2.1 AA, and ethical design systems.',
  ogImage = '/og-image.svg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://sotosili.com');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Fonts: Geist (sans) + Playfair Display (serif) -->
    <!-- Geist: Vercel CDN (not available on Google Fonts) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/geist@1.3.1/dist/fonts/geist-sans/style.css" />
    <!-- Playfair Display: weights 300/400/700 + italics 400/700 -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,300;0,400;0,700;1,300;1,400;1,700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-[#F5F2ED] text-[#1A1410] font-geist antialiased">
    {Astro.url.pathname === '/' && <EthicsGrid client:only="react" />}
    <Cursor client:only="react" />
    <slot />
  </body>
</html>
